# ===========================================
# Musician Website Template - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git - it's in .gitignore.
#
# For production (Vercel): Add these in your project Settings > Environment Variables
# ===========================================

# --- Required for Contact Form ---
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address where contact form submissions will be sent
CONTACT_EMAIL=your@email.com

# --- Optional: Custom "From" address ---
# Resend requires a verified domain. Until verified, emails send from onboarding@resend.dev
# Format: "Your Band Name <contact@yourdomain.com>"
RESEND_FROM_EMAIL=onboarding@resend.dev
